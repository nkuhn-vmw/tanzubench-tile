{
  "local_foundation": {
    "offering_name": "<%= p('tanzubench.genai_offering_name') %>",
    "plan_name": "<%= p('tanzubench.genai_plan_name') %>",
    "model_name": "<%= p('tanzubench.genai_model_name') %>",
    "engine": "<%= p('tanzubench.genai_engine') %>",
    "hardware_type": "<%= p('tanzubench.hardware_type') %>",
    "credentials_file": "/var/vcap/jobs/tanzubench-web/config/genai-credentials.json"
  },
  "external_foundations": [
    {
      "name": "<%= p('tanzubench.ext_foundation_1_name') %>",
      "endpoint": "<%= p('tanzubench.ext_foundation_1_endpoint') %>",
      "api_key": "<%= p('tanzubench.ext_foundation_1_api_key') %>",
      "model": "<%= p('tanzubench.ext_foundation_1_model') %>",
      "hardware_type": "<%= p('tanzubench.ext_foundation_1_hardware') %>"
    },
    {
      "name": "<%= p('tanzubench.ext_foundation_2_name') %>",
      "endpoint": "<%= p('tanzubench.ext_foundation_2_endpoint') %>",
      "api_key": "<%= p('tanzubench.ext_foundation_2_api_key') %>",
      "model": "<%= p('tanzubench.ext_foundation_2_model') %>",
      "hardware_type": "<%= p('tanzubench.ext_foundation_2_hardware') %>"
    }
  ],
  "judge_source": "<%= p('tanzubench.judge_source') %>",
  "task_timeout": <%= p('tanzubench.task_timeout') %>,
  "suppress_thinking": <%= p('tanzubench.suppress_thinking') %>,
  "tile_version": "<%= p('tanzubench.tile_version') %>",
  "leaderboard_route_prefix": "<%= p('tanzubench.leaderboard_route_prefix') %>",
  "export_enabled": <%= p('tanzubench.export_enabled') %>,
  "results_dir": "/var/vcap/store/tanzubench/results",
  "foundation": "<%= spec.deployment %>"
}
