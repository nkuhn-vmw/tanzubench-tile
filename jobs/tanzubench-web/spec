---
name: tanzubench-web
description: "TanzuBench local leaderboard and benchmark runner web UI"

templates:
  start.sh.erb: bin/start.sh
  stop.sh.erb: bin/stop.sh
  config.json.erb: config/config.json

packages:
  - tanzubench

consumes: []
provides: []

properties:
  tanzubench.genai_endpoint:
    description: "OpenAI-compatible model endpoint URL"
  tanzubench.genai_model:
    description: "Model name"
  tanzubench.genai_engine:
    description: "Engine type"
    default: vllm
  tanzubench.genai_api_key:
    description: "API key"
    default: ""
  tanzubench.hardware_type:
    description: "Hardware type"
    default: gpu
  tanzubench.task_timeout:
    description: "Per-test timeout override"
    default: 0
  tanzubench.suppress_thinking:
    description: "Suppress reasoning tokens"
    default: true
  tanzubench.tile_version:
    description: "GenAI tile version"
    default: ""
  tanzubench.judge_endpoint:
    description: "Judge endpoint"
    default: ""
  tanzubench.judge_model:
    description: "Judge model name"
    default: ""
  tanzubench.judge_api_key:
    description: "Judge API key"
    default: ""
  tanzubench.export_enabled:
    description: "Allow result export"
    default: true
