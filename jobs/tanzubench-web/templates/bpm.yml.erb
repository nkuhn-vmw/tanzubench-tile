processes:
  - name: tanzubench-web
    executable: /var/vcap/packages/tanzubench/bin/tanzubench-server
    args:
      - --config
      - /var/vcap/jobs/tanzubench-web/config/config.json
      - --port
      - "8080"
      - --results-dir
      - /var/vcap/store/tanzubench/results
      - --static-dir
      - /var/vcap/packages/tanzubench/web/out
    persistent_disk: true
    additional_volumes:
      - path: /var/vcap/store/tanzubench
        writable: true
