#!/bin/bash
set -euo pipefail

CREDS_FILE="/var/vcap/jobs/tanzubench-web/config/genai-credentials.json"
MODEL="<%= p('tanzubench.genai_model_name') %>"

# Resolve endpoint from marketplace credentials written by pre-start
ENDPOINT=""
API_KEY=""

if [[ -f "$CREDS_FILE" ]]; then
  ENDPOINT=$(python3 -c "import sys,json; d=json.load(open('$CREDS_FILE')); print(d.get('api_base',''))" 2>/dev/null || true)
  API_KEY=$(python3  -c "import sys,json; d=json.load(open('$CREDS_FILE')); print(d.get('api_key',''))"  2>/dev/null || true)
fi

if [[ -z "$ENDPOINT" ]]; then
  echo "=== Smoke test SKIPPED: no endpoint resolved (creds file missing or empty) ==="
  exit 0
fi

echo "=== TanzuBench Smoke Test ==="
echo "Endpoint: $ENDPOINT"
echo "Model: $MODEL"

echo -n "1. Checking /v1/models... "
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
  -H "Authorization: Bearer $API_KEY" \
  --max-time 10 \
  "$ENDPOINT/v1/models")

if [[ "$HTTP_CODE" =~ ^(200|401|403)$ ]]; then
  echo "OK (HTTP $HTTP_CODE)"
else
  echo "FAILED (HTTP $HTTP_CODE)"
  exit 1
fi

echo -n "2. Checking chat completion... "
RESPONSE=$(curl -s --max-time 120 \
  -H "Authorization: Bearer $API_KEY" \
  -H "Content-Type: application/json" \
  "$ENDPOINT/v1/chat/completions" \
  -d "{\"model\":\"$MODEL\",\"messages\":[{\"role\":\"user\",\"content\":\"What is 2+2? Answer with just the number.\"}],\"max_tokens\":8}")

if echo "$RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); c=d['choices'][0]['message']['content']; assert '4' in c" 2>/dev/null; then
  echo "OK"
else
  echo "WARN: model responded but answer may be unexpected"
  echo "Response: $(echo "$RESPONSE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['choices'][0]['message']['content'][:100])" 2>/dev/null || echo "$RESPONSE" | head -c 200)"
fi

echo "=== Smoke test passed ==="
