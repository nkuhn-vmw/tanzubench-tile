---
name: smoke-tests
description: "Errand: verify model endpoint is reachable and responds"

templates:
  run.sh.erb: bin/run

packages:
  - tanzubench
  - cf-cli

consumes: []
provides: []

properties:
  tanzubench.genai_offering_name:
    description: "CF marketplace service offering name"
    default: ""
  tanzubench.genai_model_name:
    description: "Model name"
    default: ""
  tanzubench.cf_system_domain:
    description: "CF API URL"
    default: ""
  tanzubench.cf_admin_user:
    description: "CF admin username"
    default: ""
  tanzubench.cf_admin_password:
    description: "CF admin password"
    default: ""
  tanzubench.cf_skip_ssl:
    description: "Skip SSL validation"
    default: true
