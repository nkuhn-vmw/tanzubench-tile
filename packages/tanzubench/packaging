#!/bin/bash
set -euo pipefail

# Build the Go server
export GOROOT="/var/vcap/packages/golang-1.22"
export GOPATH="${BOSH_INSTALL_TARGET}/go"
export PATH="${GOROOT}/bin:${PATH}"

mkdir -p "${BOSH_INSTALL_TARGET}/bin"
cd tanzubench-server
GOFLAGS=-mod=mod go build -o "${BOSH_INSTALL_TARGET}/bin/tanzubench-server" .

# Copy the benchmark suite
cp -r tanzubench/* "${BOSH_INSTALL_TARGET}/"
